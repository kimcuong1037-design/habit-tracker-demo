{
  "name": "habit-tracker-demo",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @habit-tracker/client --filter @habit-tracker/server dev",
    "build": "pnpm --filter @habit-tracker/shared build && pnpm --parallel --filter @habit-tracker/client --filter @habit-tracker/server build",
    "start": "NODE_ENV=production node packages/server/dist/index.js",
    "db:migrate": "cd packages/server && npx prisma migrate deploy",
    "db:seed": "cd packages/server && npx tsx prisma/seed.ts",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "pnpm --parallel -r test",
    "test:server": "pnpm --filter @habit-tracker/server test",
    "test:shared": "pnpm --filter @habit-tracker/shared test"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
